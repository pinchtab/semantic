#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

BOLD=$'\033[1m'
ACCENT=$'\033[38;2;251;191;36m'
MUTED=$'\033[38;2;90;100;128m'
SUCCESS=$'\033[38;2;0;229;204m'
ERROR=$'\033[38;2;230;57;70m'
NC=$'\033[0m'

commands=(
  "pr:рџљЂ:Pre-PR checks (check + e2e + bench)"
  "doctor:рџ©є:Setup dev environment"
  "test:рџ§Є:Run unit tests"
  "test verbose:рџ§Є:Run unit tests (verbose)"
  "test race:рџ§Є:Run unit tests with race detector"
  "coverage:рџ“Љ:Run tests with coverage report"
  "lint:рџ”Ќ:Run golangci-lint"
  "lint corpus:рџ”Ќ:Lint benchmark corpus"
  "lint docs:рџ”Ќ:Check documentation links"
  "fmt:вњЁ:Format code"
  "vet:рџ”¬:Run go vet"
  "check:вњ…:Run all checks (fmt + vet + lint + test)"
  "build:рџ“¦:Build CLI binary"
  "bench:рџЏ‹:Run corpus benchmark"
  "bench full:рџЏ‹:Run full benchmark suite"
  "baseline:рџ“Џ:Create quality baseline"
  "baseline check:рџ“Џ:Check against baseline"
  "baseline update:рџ“Џ:Update baseline (--accept)"
  "calibrate:рџЋЇ:Calibrate threshold recommendations"
  "runtime:вЏ±пёЏ:Check runtime baseline"
  "tune:рџЋ›пёЏ:Tune combined weights"
  "e2e:рџђі:Run E2E tests (Docker)"
  "loop:рџ”„:Benchmark loop (bench в†’ compare в†’ report)"
)

show_help() {
  echo ""
  echo "  ${BOLD}${ACCENT}semantic${NC} ${MUTED}вЂ” development tool${NC}"
  echo ""
  for entry in "${commands[@]}"; do
    IFS=: read -r cmd icon desc <<< "$entry"
    printf "  ${ACCENT}%-22s${NC} %s %s\n" "./dev $cmd" "$icon" "$desc"
  done
  echo ""
}

run_pr() {
  echo "  ${ACCENT}${BOLD}рџљЂ Pre-PR checks${NC}"
  echo ""

  echo "  ${MUTED}1/4 All checks (fmt + vet + lint + test)${NC}"
  run_check

  echo ""
  echo "  ${MUTED}2/4 E2E tests${NC}"
  if [[ -f tests/e2e/run.sh ]]; then
    go build -o /tmp/semantic ./cmd/semantic
    PATH="/tmp:$PATH" bash tests/e2e/run.sh
    echo "  ${SUCCESS}вњ“${NC} E2E passed"
  else
    echo "  ${MUTED}Skipped (no e2e/run.sh)${NC}"
  fi

  echo ""
  echo "  ${MUTED}3/4 Lint corpus${NC}"
  run_lint_corpus

  echo ""
  echo "  ${MUTED}4/4 Corpus benchmark${NC}"
  run_bench > /dev/null 2>&1
  echo "  ${SUCCESS}вњ“${NC} Benchmark complete"

  echo ""
  echo "  ${SUCCESS}${BOLD}рџљЂ Ready for PR${NC}"
}

run_test() {
  echo "  ${ACCENT}${BOLD}рџ§Є Running tests${NC}"
  go test ./... -count=1
  echo "  ${SUCCESS}вњ“${NC} Tests passed"
}

run_test_verbose() {
  echo "  ${ACCENT}${BOLD}рџ§Є Running tests (verbose)${NC}"
  go test ./... -count=1 -v
}

run_test_race() {
  echo "  ${ACCENT}${BOLD}рџ§Є Running tests with race detector${NC}"
  go test ./... -count=1 -race
  echo "  ${SUCCESS}вњ“${NC} Tests passed (race)"
}

run_coverage() {
  echo "  ${ACCENT}${BOLD}рџ“Љ Running tests with coverage${NC}"
  go test ./... -count=1 -coverprofile=coverage.out -covermode=atomic
  go tool cover -func=coverage.out | tail -1
  echo ""
  echo "  ${MUTED}HTML report: go tool cover -html=coverage.out${NC}"
}

run_lint() {
  echo "  ${ACCENT}${BOLD}рџ”Ќ Running linter${NC}"
  golangci-lint run
  echo "  ${SUCCESS}вњ“${NC} Lint clean"
}

run_fmt() {
  echo "  ${ACCENT}${BOLD}вњЁ Formatting code${NC}"
  gofmt -w .
  echo "  ${SUCCESS}вњ“${NC} Formatted"
}

run_vet() {
  echo "  ${ACCENT}${BOLD}рџ”¬ Running go vet${NC}"
  go vet ./...
  echo "  ${SUCCESS}вњ“${NC} Vet clean"
}

run_check() {
  echo "  ${ACCENT}${BOLD}вњ… Running all checks${NC}"
  echo ""

  echo "  ${MUTED}1/4 Format check${NC}"
  unformatted=$(gofmt -l .)
  if [ -n "$unformatted" ]; then
    echo "  ${ERROR}вњ—${NC} Unformatted files:"
    echo "$unformatted"
    exit 1
  fi
  echo "  ${SUCCESS}вњ“${NC} Format"

  echo "  ${MUTED}2/4 Vet${NC}"
  go vet ./...
  echo "  ${SUCCESS}вњ“${NC} Vet"

  echo "  ${MUTED}3/4 Lint${NC}"
  golangci-lint run
  echo "  ${SUCCESS}вњ“${NC} Lint"

  echo "  ${MUTED}4/4 Tests${NC}"
  go test ./... -count=1 -race
  echo "  ${SUCCESS}вњ“${NC} Tests"

  echo ""
  echo "  ${SUCCESS}${BOLD}All checks passed${NC}"
}

run_build() {
  echo "  ${ACCENT}${BOLD}рџ“¦ Building CLI${NC}"
  go build -o semantic ./cmd/semantic
  echo "  ${SUCCESS}вњ“${NC} Built: ./semantic"
}

run_bench() {
  echo "  ${ACCENT}${BOLD}рџЏ‹ Running corpus benchmark${NC}"
  go run ./cmd/semantic-bench check "$@"
}

run_bench_full() {
  echo "  ${ACCENT}${BOLD}рџЏ‹ Running full benchmark suite${NC}"
  go run ./cmd/semantic-bench run -suite=all "$@"
}

run_lint_corpus() {
  echo "  ${ACCENT}${BOLD}рџ”Ќ Linting benchmark corpus${NC}"
  go run ./cmd/semantic-bench lint "$@"
}

run_lint_docs() {
  echo "  ${ACCENT}${BOLD}рџ”Ќ Checking documentation links${NC}"
  bash scripts/check-docs-links.sh
}

run_baseline() {
  echo "  ${ACCENT}${BOLD}рџ“Џ Creating quality baseline${NC}"
  go run ./cmd/semantic-bench baseline create "$@"
}

run_baseline_check() {
  echo "  ${ACCENT}${BOLD}рџ“Џ Checking against baseline${NC}"
  go run ./cmd/semantic-bench check "$@"
}

run_baseline_update() {
  echo "  ${ACCENT}${BOLD}рџ“Џ Updating baseline${NC}"
  go run ./cmd/semantic-bench baseline update --accept "$@"
}

run_calibrate() {
  echo "  ${ACCENT}${BOLD}рџЋЇ Calibrating thresholds${NC}"
  go run ./cmd/semantic-bench calibrate -verbose "$@"
}

run_runtime() {
  echo "  ${ACCENT}${BOLD}вЏ±пёЏ Checking runtime baseline${NC}"
  bash tests/benchmark/scripts/check-runtime-baseline.sh "$@"
}

run_tune() {
  echo "  ${ACCENT}${BOLD}рџЋ›пёЏ Tuning combined weights${NC}"
  go run ./cmd/semantic-bench tune -verbose "$@"
}

run_e2e() {
  echo "  ${ACCENT}${BOLD}рџђі Running E2E tests${NC}"
  if [ ! -f tests/e2e/docker-compose.yml ]; then
    echo "  ${ERROR}вњ—${NC} E2E not yet set up (Phase 4)"
    exit 1
  fi
  bash scripts/e2e.sh
}

run_loop() {
  echo "  ${ACCENT}${BOLD}рџ”„ Benchmark Loop${NC}"
  go run ./cmd/semantic-bench check -verbose "$@"
}

case "${1:-help}" in
  pr)        run_pr ;;
  doctor)    exec bash scripts/doctor.sh ;;
  test)
    case "${2:-}" in
      verbose) run_test_verbose ;;
      race) run_test_race ;;
      *) run_test ;;
    esac
    ;;
  coverage)  run_coverage ;;
  lint)
    case "${2:-}" in
      corpus) run_lint_corpus ;;
      docs) run_lint_docs ;;
      *) run_lint ;;
    esac
    ;;
  fmt)       run_fmt ;;
  vet)       run_vet ;;
  check)     run_check ;;
  build)     run_build ;;
  bench|benchmark)
    case "${2:-}" in
      full) run_bench_full ;;
      *) shift; run_bench "$@" ;;
    esac
    ;;
  baseline)
    case "${2:-}" in
      check) shift 2; run_baseline_check "$@" ;;
      update) shift 2; run_baseline_update "$@" ;;
      *) shift; run_baseline "$@" ;;
    esac
    ;;
  calibrate) shift; run_calibrate "$@" ;;
  runtime)   shift; run_runtime "$@" ;;
  tune)      shift; run_tune "$@" ;;
  e2e)       run_e2e ;;
  loop)      run_loop ;;
  help|*)    show_help ;;
esac
